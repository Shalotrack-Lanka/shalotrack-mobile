<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/bottomSheetRealtimeVehicle"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet_rounded"
    android:orientation="vertical"
    android:padding="16dp"
    app:behavior_hideable="false"
    app:behavior_peekHeight="130dp"
    app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

    <!-- උඩින් තියෙන පොඩි අළු පාට ඉර (Drag Handle) -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="#D0D0D0" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- වම් පැත්තේ තියෙන අයිකන් එක (ලා නිල් කොටුව) -->
        <ImageView
            android:id="@+id/imgDeviceIcon"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_circle_gray"
            android:backgroundTint="#E3F2FD"
            android:padding="12dp"
            android:src="@android:drawable/ic_menu_compass"
            app:tint="#1877F2" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="16dp"
            android:layout_toStartOf="@id/imgFavorite"
            android:layout_toEndOf="@id/imgDeviceIcon"
            android:orientation="vertical">

            <!-- වාහනයේ / Device එකේ නම -->
            <TextView
                android:id="@+id/tvDeviceName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LT Demo Device"
                android:textColor="#000000"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- Status එක සහ වෙලාව -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="2dp">

                <TextView
                    android:id="@+id/tvDeviceStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Parked "
                    android:textColor="#1877F2"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvDeviceTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="(2h 33m ago)"
                    android:textColor="#555555"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Address එක -->
            <TextView
                android:id="@+id/tvDeviceAddress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Loading address..."
                android:textColor="#888888"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- දකුණු පැත්තේ තියෙන Heart අයිකන් එක -->
        <ImageView
            android:id="@+id/imgFavorite"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:src="@android:drawable/ic_menu_myplaces"
            app:tint="#BDBDBD" />
    </RelativeLayout>
</LinearLayout>