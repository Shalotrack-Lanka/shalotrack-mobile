<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="24dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center"
        android:background="#FFFFFF">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Email sent\nsuccessfully"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:textAlignment="center" />

        <LinearLayout
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:background="@drawable/bg_circle_border"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/txtTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="174"
                android:textSize="45sp"
                android:textStyle="bold"
                android:textColor="#1877F2" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sec"
                android:textSize="16sp"
                android:textColor="#1877F2" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="A verification link has been sent to your email. Just click the button in the email to verify your account."
            android:textAlignment="center"
            android:textSize="15sp"
            android:textColor="#000000"
            android:layout_marginBottom="24dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOpenEmail"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Open email"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            app:cornerRadius="12dp"
            app:backgroundTint="#1877F2"/>

        <TextView
            android:id="@+id/btnCancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancel"
            android:textColor="#1877F2"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:padding="8dp"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>