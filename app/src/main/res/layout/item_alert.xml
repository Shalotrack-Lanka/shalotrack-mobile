<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="0dp"
    app:strokeColor="#E0E0E0"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- Unread indicator dot - shape/color set in code (AlertAdapter), not a
             drawable resource, to avoid depending on a file that might not exist. -->
        <View
            android:id="@+id/dotUnread"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_marginEnd="12dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvAlertType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ignition On"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#0A2463" />

            <TextView
                android:id="@+id/tvAlertMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Test: ignition turned on"
                android:textSize="13sp"
                android:textColor="#555555" />

            <TextView
                android:id="@+id/tvAlertVehicle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="WP JK 9931"
                android:textSize="11sp"
                android:textColor="#888888" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvAlertTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10:02 AM"
            android:textSize="11sp"
            android:textColor="#888888" />
    </LinearLayout>
</androidx.cardview.widget.CardView>